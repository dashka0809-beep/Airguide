# dbmate migration файлууд энд нэмэгдэнэ.
#
# Нэрлэх формат:  YYYYMMDDHHMMSS_description.sql
# Жишээ:          20260520120000_add_seats_table.sql
#
# Файлын дотор:
#   -- migrate:up
#   CREATE TABLE seats (...);
#
#   -- migrate:down
#   DROP TABLE seats;
#
# Дэлгэрэнгүй: ../docs/DATABASE.md#10-migration-дүрэм-dbmate
