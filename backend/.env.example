# ============================================================
# Air Guide API — Environment Variables Template
# Энэ файлыг .env гэж нэрлэж хуулаад, утгуудаа бөглөнө.
# .env файл нь .gitignore-д орсон тул GitHub руу orохгүй.
# ============================================================

# ----- Server -----
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ----- Database -----
# Local Postgres жишээ:
DATABASE_URL=postgresql://airguide:devpassword@127.0.0.1:5432/airguide_db
# Railway production жишээ:
# DATABASE_URL=${{Postgres.DATABASE_URL}}

DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000

# ----- Auth (Phase 1+) -----
# openssl rand -hex 32 - аар үүсгэнэ
JWT_SECRET=change_me_to_long_random_string_min_32_chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
BCRYPT_COST=12

# ----- CORS -----
# Production: frontend-ийн яг URL. Таслалаар олон origin бичиж болно.
# '*' = бүгдэд нээлттэй (зөвхөн dev — production-д бүү ашигла).
FRONTEND_ORIGIN=http://localhost:5173

# ----- QPay (Phase 3) -----
QPAY_BASE_URL=https://merchant.qpay.mn/v2
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=

# ----- Email (Phase 3) -----
RESEND_API_KEY=
EMAIL_FROM=noreply@airguide.mn

# ----- Monitoring (Phase 5) — optional, байхгүй бол no-op -----
SENTRY_DSN=

# ----- AI chatbot (Phase 6) — optional, байхгүй бол /api/chat 503 -----
ANTHROPIC_API_KEY=
CHAT_MODEL=claude-sonnet-4-6

# ----- Travelport (sandbox прототайп) — optional, байхгүй бол /api/travelport 503 -----
# Travelport Developer Portal-аас sandbox/pre-production эрх авна.
TRAVELPORT_ENV=sandbox
TRAVELPORT_OAUTH_URL=
TRAVELPORT_BASE_URL=
TRAVELPORT_CLIENT_ID=
TRAVELPORT_CLIENT_SECRET=
TRAVELPORT_USERNAME=
TRAVELPORT_PASSWORD=
TRAVELPORT_PCC=
